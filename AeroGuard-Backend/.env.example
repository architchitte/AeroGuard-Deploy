# =================================================================
# AeroGuard Backend - Environment Configuration Example
# Copy this file to .env and fill in your actual API keys.
# =================================================================

# --- Air Quality API (World Air Quality Index) ---
# Get your free token at: https://aqicn.org/data-platform/token/
REALTIME_AQI_API_KEY=your_waqi_token_here

# --- AI Provider API (NVIDIA NIM / Qwen) ---
# Get your API key at: https://build.nvidia.com/qwen/qwen3-coder-480b-instruct
NVIDIA_QWEN_API_KEY=your_nvidia_api_key_here

# --- Security & Configuration ---
# Generate a secure key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_super_secret_app_key_here
JWT_SECRET_KEY=your_jwt_signing_key_here

# Database URL (Defaulting to local SQLite)
DATABASE_URL=your_database_url

# --- CORS Origins ---
# For development, you can use ["*"]. For production, list your frontend domains.
# Format: JSON-style list of strings
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# --- Operational Settings ---
LOG_LEVEL=INFO
MODEL_CACHE_TIMEOUT=3600
MAX_REQUEST_SIZE=1048576
